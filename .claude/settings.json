{
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(cd:*)",
      "Bash(uv run:*)",
      "Bash(git diff)",
      "Bash(git mv:*)",
      "Read",
      "Edit(**/*.py)",
      "Edit(**/*.sh)",
      "Edit(**/*.md)",
      "Edit(**/*.yaml)",
      "Edit(**/*.json)",
      "Edit(**/*.toml)",
      "Write(**/*.py)",
      "Write(**/*.sh)",
      "Write(**/*.md)",
      "Write(**/*.yaml)",
      "Write(**/*.json)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(grep:*)"
    ]
  },
  "teammateMode": "tmux",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
